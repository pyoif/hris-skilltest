{
  "name": "hris-backend",
  "version": "1.0.0",
  "description": "HRIS Technical Test - Backend (Express.js with PostgreSQL)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "bun:dev": "bun src/index.ts",
    "build": "tsc",
    "bun:build": "bun build ./src/index.ts --outdir ./dist",
    "start": "node dist/index.js",
    "bun:start": "bun dist/index.js",
    "init-db": "ts-node src/scripts/initDb.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.4",
    "@types/pg": "^8.10.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
